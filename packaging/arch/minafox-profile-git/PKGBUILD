# Maintainer: MinaFox maintainers
pkgname=minafox-profile-git
pkgver=0.1.0.r5.gbe77521
pkgrel=2
pkgdesc="MinaFox standalone Firefox profile wrapper for Arch/Hyprland"
arch=('any')
url="https://github.com/KawaiiMina/Minafox"
license=('MPL-2.0')
depends=('firefox' 'desktop-file-utils' 'hicolor-icon-theme' 'python')
makedepends=('git')
optdepends=(
  'docker: run the optional local MinaFox SearXNG service with Docker Engine'
  'docker-compose: provide Docker Compose for the optional local MinaFox SearXNG service'
  'podman: run the optional local MinaFox SearXNG service without Docker'
  'podman-compose: provide Podman Compose for the optional local MinaFox SearXNG service'
)
provides=('minafox-profile')
conflicts=('minafox-profile')
install="${pkgname}.install"
_minafox_source_ref='v0.1.0-rc2'
# Release-candidate builds intentionally pin the fetched source. Once
# v0.1.0-rc2 is created, public makepkg builds cannot drift when main advances.
source=("Minafox::git+https://github.com/KawaiiMina/Minafox.git#tag=${_minafox_source_ref}")
sha256sums=('SKIP')

package() {
  cd "$srcdir/Minafox"

  install -Dm755 scripts/minafox-launcher.sh "$pkgdir/usr/bin/minafox"
  install -Dm755 scripts/minafox-update.sh "$pkgdir/usr/bin/minafox-update"
  install -Dm755 scripts/minafox-ai-broker.sh "$pkgdir/usr/bin/minafox-ai-broker"

  install -Dm644 desktop/minafox.desktop "$pkgdir/usr/share/applications/minafox.desktop"
  install -d "$pkgdir/usr/share/icons"
  cp -a assets/icons/hicolor "$pkgdir/usr/share/icons/"

  install -Dm644 README.md "$pkgdir/usr/share/doc/minafox/README.md"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 BRANDING.md "$pkgdir/usr/share/doc/minafox/BRANDING.md"
  install -Dm644 THIRD_PARTY_LICENSES.md "$pkgdir/usr/share/doc/minafox/THIRD_PARTY_LICENSES.md"
  install -Dm644 docs/brand-lore.md "$pkgdir/usr/share/doc/minafox/brand-lore.md"
  install -Dm644 docs/ai-provider-architecture.md "$pkgdir/usr/share/doc/minafox/ai-provider-architecture.md"
  install -Dm644 docs/licensing-and-source-fork.md "$pkgdir/usr/share/doc/minafox/licensing-and-source-fork.md"
  install -d "$pkgdir/usr/share/minafox"
  cp -a assets "$pkgdir/usr/share/minafox/"
  install -Dm644 desktop/start.html "$pkgdir/usr/share/minafox/desktop/start.html"
  install -Dm644 desktop/minafox.desktop "$pkgdir/usr/share/minafox/desktop/minafox.desktop"
  install -Dm644 distribution/policies.json "$pkgdir/usr/share/minafox/distribution/policies.json"
  install -Dm644 profile/user.js "$pkgdir/usr/share/minafox/profile/user.js"
  install -Dm644 profile/userChrome.css "$pkgdir/usr/share/minafox/profile/userChrome.css"
  install -Dm644 profile/userContent.css "$pkgdir/usr/share/minafox/profile/userContent.css"

  install -Dm755 scripts/install-minafox-arch.sh "$pkgdir/usr/share/minafox/scripts/install-minafox-arch.sh"
  install -Dm755 scripts/minafox-launcher.sh "$pkgdir/usr/share/minafox/scripts/minafox-launcher.sh"
  install -Dm755 scripts/minafox-update.sh "$pkgdir/usr/share/minafox/scripts/minafox-update.sh"
  install -Dm755 scripts/minafox-ai-broker.py "$pkgdir/usr/share/minafox/scripts/minafox-ai-broker.py"
  install -Dm755 scripts/serve-minafox-mobile.py "$pkgdir/usr/share/minafox/scripts/serve-minafox-mobile.py"
  install -Dm755 scripts/minafox-ai-broker.sh "$pkgdir/usr/share/minafox/scripts/minafox-ai-broker.sh"
  install -Dm755 scripts/install-minafox-searxng-arch.sh "$pkgdir/usr/share/minafox/scripts/install-minafox-searxng-arch.sh"
  install -Dm644 systemd/user/minafox-searxng.service "$pkgdir/usr/lib/systemd/user/minafox-searxng.service"
  install -Dm644 systemd/user/minafox-ai-broker.service "$pkgdir/usr/lib/systemd/user/minafox-ai-broker.service"
  install -Dm644 systemd/user/minafox-mobile-harness.service "$pkgdir/usr/lib/systemd/user/minafox-mobile-harness.service"

  install -Dm644 searxng/README.md "$pkgdir/usr/share/minafox/searxng/README.md"
  install -Dm644 searxng/Dockerfile "$pkgdir/usr/share/minafox/searxng/Dockerfile"
  install -Dm644 searxng/docker-compose.yml "$pkgdir/usr/share/minafox/searxng/docker-compose.yml"
  install -Dm644 searxng/settings.yml "$pkgdir/usr/share/minafox/searxng/settings.yml"
  install -Dm644 searxng/uwsgi.ini "$pkgdir/usr/share/minafox/searxng/uwsgi.ini"
  install -Dm755 searxng/patch-base-template.py "$pkgdir/usr/share/minafox/searxng/patch-base-template.py"
  install -Dm644 searxng/theme/minafox.css "$pkgdir/usr/share/minafox/searxng/theme/minafox.css"
  install -Dm644 searxng/theme/minafox-categories.js "$pkgdir/usr/share/minafox/searxng/theme/minafox-categories.js"
}
